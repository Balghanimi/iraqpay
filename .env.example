# IraqPay — Environment Variables
# Copy this file to .env and fill in your credentials

# ── ZainCash ──────────────────────────────────────────────
ZAINCASH_MSISDN=9647XXXXXXXXX
ZAINCASH_MERCHANT_ID=your_merchant_id
ZAINCASH_SECRET=your_secret

# ── FIB (First Iraqi Bank) ────────────────────────────────
FIB_CLIENT_ID=your_client_id
FIB_CLIENT_SECRET=your_client_secret

# ── QiCard ────────────────────────────────────────────────
QICARD_USERNAME=your_username
QICARD_PASSWORD=your_password
QICARD_TERMINAL_ID=your_terminal_id

# ── NassPay ───────────────────────────────────────────────
NASSPAY_USERNAME=your_merchant_username
NASSPAY_PASSWORD=your_merchant_password

# ── Server ────────────────────────────────────────────────
PORT=3000
IRAQPAY_SANDBOX=true
