# IraqPay — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# If credentials were ever committed, rotate them immediately.

# ── ZainCash ──────────────────────────────────────────────
IRAQPAY_ZAINCASH_MSISDN=9647XXXXXXXXX
IRAQPAY_ZAINCASH_MERCHANT_ID=your_merchant_id
IRAQPAY_ZAINCASH_SECRET=your_secret

# ── FIB (First Iraqi Bank) ────────────────────────────────
IRAQPAY_FIB_CLIENT_ID=your_client_id
IRAQPAY_FIB_CLIENT_SECRET=your_client_secret

# ── QiCard ────────────────────────────────────────────────
IRAQPAY_QICARD_USERNAME=your_username
IRAQPAY_QICARD_PASSWORD=your_password
IRAQPAY_QICARD_TERMINAL_ID=your_terminal_id

# ── NassPay ───────────────────────────────────────────────
IRAQPAY_NASSPAY_USERNAME=your_merchant_username
IRAQPAY_NASSPAY_PASSWORD=your_merchant_password

# ── General ───────────────────────────────────────────────
IRAQPAY_SANDBOX=true
PORT=3000
